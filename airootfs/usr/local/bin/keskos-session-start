#!/usr/bin/env bash
set -euo pipefail

LOG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/keskos"
LOG_FILE="${LOG_DIR}/session-start.log"
LOCK_FILE="${LOG_DIR}/session-start.lock"

mkdir -p "$LOG_DIR"
touch "$LOG_FILE"

exec 9>"$LOCK_FILE"
if ! flock -n 9; then
  exit 0
fi

{
  printf '[%s] starting session helpers\n' "$(date --iso-8601=seconds)"
  /usr/local/bin/keskos-configure-user || true
  /usr/local/bin/keskos-wallpaper-apply || true
  /usr/local/bin/keskos-start-quickshell || true
  printf '[%s] session helpers finished\n' "$(date --iso-8601=seconds)"
} >>"$LOG_FILE" 2>&1

