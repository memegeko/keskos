#!/usr/bin/env bash
set -euo pipefail

ENTRYPOINT="/usr/local/share/keskos/source/configs/quickshell/main.qml"
SELECT_RESOLUTION="/usr/local/bin/keskos-select-resolution"
RESOLUTION_ENV="${HOME}/.config/quickshell/keskos-resolution.env"
LOG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/keskos"
LOG_FILE="${LOG_DIR}/quickshell.log"

resolve_quickshell_bin() {
  if command -v quickshell >/dev/null 2>&1; then
    command -v quickshell
    return 0
  fi

  return 1
}

main() {
  local quickshell_bin=""

  [[ "${KESKOS_DISABLE_HUD:-0}" != "1" ]] || exit 0

  mkdir -p "$LOG_DIR" "$(dirname "$RESOLUTION_ENV")"
  : >"$LOG_FILE"

  if ! quickshell_bin="$(resolve_quickshell_bin)"; then
    printf '[keskos-hud] quickshell was not found; skipping HUD startup\n' >>"$LOG_FILE"
    exit 0
  fi

  if [[ ! -f "$ENTRYPOINT" ]]; then
    printf '[keskos-hud] quickshell entrypoint missing: %s\n' "$ENTRYPOINT" >>"$LOG_FILE"
    exit 0
  fi

  pkill -x quickshell >/dev/null 2>&1 || true
  sleep 2

  if [[ -x "$SELECT_RESOLUTION" ]]; then
    "$SELECT_RESOLUTION" >>"$LOG_FILE" 2>&1 || true
  fi

  if [[ -f "$RESOLUTION_ENV" ]]; then
    # shellcheck disable=SC1090
    . "$RESOLUTION_ENV"
  fi

  nohup env \
    QS_NO_RELOAD_POPUP=1 \
    KESKOS_QS_PROFILE="${KESKOS_QS_PROFILE:-1080p}" \
    KESKOS_QS_SCALE="${KESKOS_QS_SCALE:-0.468750}" \
    KESKOS_QS_WIDTH="${KESKOS_QS_WIDTH:-1920}" \
    KESKOS_QS_HEIGHT="${KESKOS_QS_HEIGHT:-1080}" \
    "$quickshell_bin" --path "$ENTRYPOINT" >>"$LOG_FILE" 2>&1 &
}

main "$@"

