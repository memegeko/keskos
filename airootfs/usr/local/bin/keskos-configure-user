#!/usr/bin/env bash
set -euo pipefail

SOURCE_ROOT="/usr/local/share/keskos/source"
OFFLINE=0
FORCE=0
TARGET_USER="${TARGET_USER:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --offline)
      OFFLINE=1
      shift
      ;;
    --force|--refresh)
      FORCE=1
      shift
      ;;
    --user)
      TARGET_USER="${2:-}"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

log() {
  printf '[keskos-user] %s\n' "$1"
}

kwriteconfig_bin=""
if command -v kwriteconfig6 >/dev/null 2>&1; then
  kwriteconfig_bin="kwriteconfig6"
elif command -v kwriteconfig5 >/dev/null 2>&1; then
  kwriteconfig_bin="kwriteconfig5"
fi

kbuildsycoca_bin=""
if command -v kbuildsycoca6 >/dev/null 2>&1; then
  kbuildsycoca_bin="kbuildsycoca6"
elif command -v kbuildsycoca5 >/dev/null 2>&1; then
  kbuildsycoca_bin="kbuildsycoca5"
fi

qdbus_bin=""
if command -v qdbus6 >/dev/null 2>&1; then
  qdbus_bin="qdbus6"
elif command -v qdbus >/dev/null 2>&1; then
  qdbus_bin="qdbus"
fi

resolve_target_user() {
  if [[ -n "$TARGET_USER" ]]; then
    return
  fi

  if [[ ${EUID} -eq 0 && -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    TARGET_USER="${SUDO_USER}"
  else
    TARGET_USER="$(id -un)"
  fi
}

resolve_target_home() {
  TARGET_HOME="$(getent passwd "$TARGET_USER" | cut -d: -f6)"
  if [[ -z "${TARGET_HOME:-}" ]]; then
    printf '[keskos-user] error: could not resolve the home directory for %s\n' "$TARGET_USER" >&2
    exit 1
  fi
}

ensure_dirs() {
  mkdir -p \
    "$TARGET_HOME/.config/fastfetch" \
    "$TARGET_HOME/.config/keskos" \
    "$TARGET_HOME/.config" \
    "$TARGET_HOME/.config/quickshell" \
    "$TARGET_HOME/.config/autostart" \
    "$TARGET_HOME/.local/state/keskos" \
    "$TARGET_HOME/Desktop"
}

copy_default() {
  local source_path="$1"
  local target_path="$2"
  local mode="$3"

  if [[ "$FORCE" -eq 1 || ! -f "$target_path" ]]; then
    install -Dm"$mode" "$source_path" "$target_path"
  fi

  if [[ ${EUID} -eq 0 ]]; then
    chown "$TARGET_USER:$TARGET_USER" "$target_path"
  fi
}

write_if_needed() {
  local target_path="$1"
  local mode="$2"
  local temp_file

  temp_file="$(mktemp)"
  cat >"$temp_file"

  if [[ "$FORCE" -eq 1 || ! -f "$target_path" ]] || ! cmp -s "$temp_file" "$target_path"; then
    install -Dm"$mode" "$temp_file" "$target_path"
  fi

  rm -f "$temp_file"

  if [[ ${EUID} -eq 0 ]]; then
    chown "$TARGET_USER:$TARGET_USER" "$target_path"
  fi
}

write_bash_overlay() {
  write_if_needed "$TARGET_HOME/.config/keskos/bashrc" 644 <<'EOF'
# KeskOS Bash prompt overlay

if [[ -r /etc/bash.bashrc ]]; then
  # shellcheck disable=SC1091
  . /etc/bash.bashrc
fi

if [[ -r "$HOME/.bashrc" ]]; then
  # shellcheck disable=SC1090
  . "$HOME/.bashrc"
fi

export HOSTNAME="keskos"
PS1='\[\e[38;2;206;106;53m\]keskos :: \W > \[\e[0m\]'
EOF
}

install_fastfetch_assets() {
  copy_default "$SOURCE_ROOT/configs/fastfetch/config.jsonc" "$TARGET_HOME/.config/fastfetch/config.jsonc" 644
  copy_default "$SOURCE_ROOT/configs/fastfetch/logo.txt" "$TARGET_HOME/.config/fastfetch/logo.txt" 644
}

install_autostart_entry() {
  local source_entry="/etc/skel/.config/autostart/keskos-session-start.desktop"
  local target_entry="$TARGET_HOME/.config/autostart/keskos-session-start.desktop"
  if [[ -f "$source_entry" ]]; then
    copy_default "$source_entry" "$target_entry" 644
  fi
}

configure_default_apps() {
  write_if_needed "$TARGET_HOME/.config/mimeapps.list" 644 <<'EOF'
[Default Applications]
x-scheme-handler/http=firefox.desktop
x-scheme-handler/https=firefox.desktop
text/html=firefox.desktop
application/xhtml+xml=firefox.desktop
inode/directory=dolphin.desktop
EOF
}

install_live_desktop_shortcuts() {
  local source_entry=""
  local file_name=""

  [[ "$TARGET_USER" == "liveuser" ]] || return 0

  for source_entry in \
    /usr/share/applications/install-keskos.desktop \
    /usr/share/applications/keskos-launcher.desktop \
    /usr/share/applications/keskos-browser.desktop \
    /usr/share/applications/keskos-files.desktop
  do
    [[ -f "$source_entry" ]] || continue
    file_name="$(basename "$source_entry")"
    copy_default "$source_entry" "$TARGET_HOME/Desktop/$file_name" 755
  done
}

write_application_shortcut() {
  local desktop_id="$1"
  local shortcut_value="$2"
  local shortcuts_file="$TARGET_HOME/.config/kglobalshortcutsrc"

  "$kwriteconfig_bin" --file "$shortcuts_file" --group "services/$desktop_id" --key "_launch" "$shortcut_value"
  "$kwriteconfig_bin" --file "$shortcuts_file" --group "$desktop_id" --key "_launch" "$shortcut_value"
}

configure_shortcuts() {
  local shortcuts_file="$TARGET_HOME/.config/kglobalshortcutsrc"
  local kwin_file="$TARGET_HOME/.config/kwinrc"
  local meta_action="org.kde.kglobalaccel,/component/keskos_launcher_desktop,org.kde.kglobalaccel.Component,invokeShortcut,_launch"

  [[ -n "$kwriteconfig_bin" ]] || return 0

  "$kwriteconfig_bin" --file "$kwin_file" --group ModifierOnlyShortcuts --key Meta "$meta_action"
  "$kwriteconfig_bin" --file "$shortcuts_file" --group plasmashell --key "activate application launcher" "Alt+F1,Alt+F1,Activate Application Launcher" >/dev/null 2>&1 || true
  "$kwriteconfig_bin" --file "$shortcuts_file" --group kwin --key "Edit Tiles" "none,none,Toggle Tiles Editor" >/dev/null 2>&1 || true
  "$kwriteconfig_bin" --file "$shortcuts_file" --group kwin --key Overview "none,none,Toggle Overview" >/dev/null 2>&1 || true
  "$kwriteconfig_bin" --file "$shortcuts_file" --group kwin --key "Walk Through Windows (Reverse)" "Alt+Shift+Tab,Alt+Shift+Tab,Walk Through Windows (Reverse)" >/dev/null 2>&1 || true

  write_application_shortcut "keskos-launcher.desktop" "Meta+K,Meta+K,KESKOS Launcher"
  write_application_shortcut "keskos-terminal.desktop" $'Meta+T\tMeta+Return,Meta+T\tMeta+Return,KESKOS Terminal'
  write_application_shortcut "keskos-files.desktop" "Meta+N,Meta+N,KESKOS Files"
  write_application_shortcut "keskos-browser.desktop" "Meta+W,Meta+W,KESKOS Browser"
  write_application_shortcut "keskos-launcher-apps.desktop" "Meta+Shift+K,Meta+Shift+K,KESKOS Apps"
  write_application_shortcut "keskos-launcher-windows.desktop" "Meta+Shift+Tab,Meta+Shift+Tab,KESKOS Windows"
  write_application_shortcut "keskos-launcher-settings.desktop" "Meta+Shift+S,Meta+Shift+S,KESKOS Settings"
  write_application_shortcut "keskos-launcher-power.desktop" "Meta+P,Meta+P,KESKOS Power"
}

configure_terminal() {
  local konsolerc="$TARGET_HOME/.config/konsolerc"

  [[ -n "$kwriteconfig_bin" ]] || return 0

  "$kwriteconfig_bin" --file "$konsolerc" --group "Desktop Entry" --key DefaultProfile "KeskOS.profile"
}

configure_kde_visuals() {
  local kdeglobals="$TARGET_HOME/.config/kdeglobals"
  local kwin_file="$TARGET_HOME/.config/kwinrc"

  [[ -n "$kwriteconfig_bin" ]] || return 0

  "$kwriteconfig_bin" --file "$kdeglobals" --group General --key ColorScheme "KESKOS"
  "$kwriteconfig_bin" --file "$kdeglobals" --group General --key font "JetBrainsMono Nerd Font,10,-1,5,50,0,0,0,0,0"
  "$kwriteconfig_bin" --file "$kdeglobals" --group General --key fixed "JetBrainsMono Nerd Font,10,-1,5,50,0,0,0,0,0"
  "$kwriteconfig_bin" --file "$kdeglobals" --group General --key smallestReadableFont "JetBrainsMono Nerd Font,8,-1,5,50,0,0,0,0,0"
  "$kwriteconfig_bin" --file "$kdeglobals" --group General --key menuFont "JetBrainsMono Nerd Font,10,-1,5,50,0,0,0,0,0"
  "$kwriteconfig_bin" --file "$kdeglobals" --group General --key toolBarFont "JetBrainsMono Nerd Font,10,-1,5,50,0,0,0,0,0"
  "$kwriteconfig_bin" --file "$kwin_file" --group org.kde.kdecoration2 --key library "org.kde.kwin.aurorae"
  "$kwriteconfig_bin" --file "$kwin_file" --group org.kde.kdecoration2 --key theme "kwin4_decoration_qml_keskos_split"
  "$kwriteconfig_bin" --file "$kwin_file" --group org.kde.kdecoration2 --key BorderSize "Normal"
  "$kwriteconfig_bin" --file "$kwin_file" --group org.kde.kdecoration2 --key BorderSizeAuto false
  "$kwriteconfig_bin" --file "$kwin_file" --group Windows --key BorderlessMaximizedWindows false
}

configure_lockscreen_and_splash() {
  local kscreenlockerrc="$TARGET_HOME/.config/kscreenlockerrc"
  local ksplashrc="$TARGET_HOME/.config/ksplashrc"
  local background_path="/usr/share/plasma/shells/org.kde.plasma.desktop/contents/lockscreen/assets/background.png"

  [[ -n "$kwriteconfig_bin" ]] || return 0

  "$kwriteconfig_bin" --file "$kscreenlockerrc" --group Greeter --key WallpaperPlugin "org.kde.image"
  "$kwriteconfig_bin" --file "$kscreenlockerrc" --group Greeter --group Wallpaper --group org.kde.image --group General --key Image "file://$background_path"
  "$kwriteconfig_bin" --file "$kscreenlockerrc" --group Greeter --group Wallpaper --group org.kde.image --group General --key FillMode "2"
  "$kwriteconfig_bin" --file "$ksplashrc" --group KSplash --key Engine "KSplashQML"
  "$kwriteconfig_bin" --file "$ksplashrc" --group KSplash --key Theme "com.keskos.desktop"
}

maybe_set_panel_autohide() {
  local script

  [[ "$OFFLINE" -eq 0 ]] || return 0
  [[ -n "$qdbus_bin" ]] || return 0

  script='for (var i = 0; i < panelIds.length; i++) {
  try {
    var panel = panelById(panelIds[i]);
    if (panel) {
      panel.hiding = "autohide";
    }
  } catch (error) {
  }
}'

  "$qdbus_bin" org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "$script" >/dev/null 2>&1 || true
}

refresh_runtime() {
  [[ "$OFFLINE" -eq 0 ]] || return 0

  if [[ -n "$kbuildsycoca_bin" ]]; then
    "$kbuildsycoca_bin" >/dev/null 2>&1 || true
  fi

  if [[ -n "$qdbus_bin" ]]; then
    "$qdbus_bin" org.kde.KWin /KWin reconfigure >/dev/null 2>&1 || true
  fi
}

fix_ownership() {
  local owned_paths=(
    "$TARGET_HOME/.config/fastfetch"
    "$TARGET_HOME/.config/keskos"
    "$TARGET_HOME/.config/quickshell"
    "$TARGET_HOME/.config/autostart/keskos-session-start.desktop"
    "$TARGET_HOME/.config/konsolerc"
    "$TARGET_HOME/.config/kdeglobals"
    "$TARGET_HOME/.config/kglobalshortcutsrc"
    "$TARGET_HOME/.config/kwinrc"
    "$TARGET_HOME/.config/kscreenlockerrc"
    "$TARGET_HOME/.config/ksplashrc"
    "$TARGET_HOME/.local/state/keskos"
  )

  if [[ ${EUID} -eq 0 ]]; then
    for path in "${owned_paths[@]}"; do
      [[ -e "$path" ]] || continue
      chown -R "$TARGET_USER:$TARGET_USER" "$path"
    done
  fi
}

main() {
  resolve_target_user
  resolve_target_home
  ensure_dirs
  install_fastfetch_assets
  write_bash_overlay
  install_autostart_entry
  configure_default_apps
  install_live_desktop_shortcuts
  configure_terminal
  configure_kde_visuals
  configure_shortcuts
  configure_lockscreen_and_splash
  maybe_set_panel_autohide
  refresh_runtime
  fix_ownership
  log "Configured KeskOS defaults for ${TARGET_USER}"
}

main "$@"
