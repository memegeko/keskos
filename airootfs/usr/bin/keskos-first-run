#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/keskos"
LOG_FILE="${STATE_DIR}/first-run.log"

mkdir -p "$STATE_DIR"
printf '[%s] wrapper launch args=%s\n' "$(date --iso-8601=seconds)" "$*" >>"$LOG_FILE"

exec python3 /usr/lib/keskos-first-run/main.py "$@" >>"$LOG_FILE" 2>&1
